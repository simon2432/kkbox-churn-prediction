# =============================================================================
# Data — never commit raw or processed CSVs to Git
# =============================================================================
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Large archive
*.zip

# =============================================================================
# Jupyter Notebooks — strip outputs before committing (optional)
# =============================================================================
# Uncomment the lines below if you use nbstripout to auto-clean outputs
# .ipynb_checkpoints/
# */.ipynb_checkpoints/

# Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# =============================================================================
# Model artifacts and outputs
# =============================================================================
models/
outputs/
*.pkl
*.joblib
*.h5
*.pt
*.ckpt

# =============================================================================
# OS / IDE
# =============================================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# =============================================================================
# Misc
# =============================================================================
*.log
*.tmp
